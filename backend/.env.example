# PostgreSQL — use Supabase connection string (Settings → Database → URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# JWT signing secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret

# Google AI Studio API key — get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# AI model — gemini-2.5-flash works reliably; swap for gemma-4-27b-it if available
GEMMA_MODEL=gemini-2.5-flash

# Your Vercel frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-app.vercel.app
